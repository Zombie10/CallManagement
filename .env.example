# LiveKit Configuration (required for the agent server + SIP)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=AP...
LIVEKIT_API_SECRET=...

# ============================================
# xAI Configuration (RECOMMENDED for voice)
# ============================================
# Get your key at https://console.x.ai/
XAI_API_KEY=xai-...

# Choose how to use xAI:
# - Full Grok Voice Agent API (best quality, lowest latency)
MODEL_PROVIDER=xai
USE_GROK_REALTIME=true
GROK_REALTIME_MODEL=grok-voice-think-fast-1.0   # Current flagship fast voice model from xAI
GROK_REALTIME_VOICE=Ara

# Alternative: Use individual xAI components (classic pipeline)
# USE_GROK_REALTIME=false
# XAI_STT_MODEL=grok-stt
# XAI_LLM_MODEL=grok-3
# XAI_TTS_MODEL=grok-tts
# XAI_TTS_VOICE=Ara

# ============================================
# Alternative providers (if not using xAI)
# ============================================
# LiveKit Inference (one key for everything)
# MODEL_PROVIDER=inference
# STT_MODEL=deepgram/nova-3
# LLM_MODEL=openai/gpt-4.1-mini
# TTS_MODEL=cartesia/sonic-3
# TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc

# Direct keys (classic plugins)
# OPENAI_API_KEY=sk-...
# DEEPGRAM_API_KEY=...
# CARTESIA_API_KEY=...
# ELEVENLABS_API_KEY=...

# Optional: SIP Trunk for outbound calls
SIP_TRUNK_ID=ST_...

# Application settings
LOG_LEVEL=INFO
CRM_DB_PATH=./data/crm.db

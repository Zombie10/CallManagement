# =============================================================================
# LiveKit — worker (dev/start), LiveKit voice playground, SIP inbound
# Get keys: https://cloud.livekit.io → Project → Settings → Keys
#
# Same project uses different hostnames:
#   Project ID:  p_39db3sg0f79          (internal)
#   SIP URI:     sip:39db3sg0f79.sip.livekit.cloud   (external SIP trunks only)
#   WebSocket:   wss://call-management-6g9fmqf0.livekit.cloud  (put THIS in LIVEKIT_URL)
#
# After setting keys, create dispatch rule:
#   uv run python scripts/setup_livekit_inbound.py --phone +15109379101
# See docs/TELEPHONY.md
# =============================================================================
LIVEKIT_URL=wss://call-management-6g9fmqf0.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...

# =============================================================================
# xAI — recommended for voice (admin playground + agent worker)
# Get your key at https://console.x.ai/
# =============================================================================
XAI_API_KEY=xai-...

MODEL_PROVIDER=xai
USE_GROK_REALTIME=true
GROK_REALTIME_MODEL=grok-voice-latest
GROK_REALTIME_VOICE=ara

# xAI built-in tools (server-side). Custom CRM/SIP tools run locally.
XAI_ENABLE_WEB_SEARCH=true
XAI_ENABLE_X_SEARCH=false
XAI_ENABLE_FILE_SEARCH=false
XAI_ENABLE_CODE_INTERPRETER=false
# XAI_VECTOR_STORE_IDS=vs_abc123
# XAI_ALLOWED_X_HANDLES=@yourcompany,@support
# XAI_MAX_FILE_SEARCH_RESULTS=5

# xAI Remote MCP (xAI connects to external MCP servers on your behalf)
XAI_ENABLE_REMOTE_MCP=false
# XAI_MCP_SERVERS=[{"id":"deepwiki","server_url":"https://mcp.deepwiki.com/mcp","server_label":"deepwiki","agents":["technical"]},{"id":"knowledge","server_url":"https://kb.example.com/mcp","server_label":"knowledge","allowed_tools":["search_articles"],"authorization_env":"KB_MCP_TOKEN","agents":["support"]},{"id":"tickets","server_url":"https://zendesk.example.com/mcp","server_label":"zendesk","agents":["support","escalation"]}]
# KB_MCP_TOKEN=your-mcp-bearer-token

# Classic xAI pipeline (when USE_GROK_REALTIME=false)
# XAI_STT_MODEL=grok-stt
# XAI_LLM_MODEL=grok-3
# XAI_TTS_MODEL=grok-tts
# XAI_TTS_VOICE=Ara

# =============================================================================
# Alternative providers (if not using xAI)
# =============================================================================
# MODEL_PROVIDER=inference
# STT_MODEL=deepgram/nova-3
# LLM_MODEL=openai/gpt-4.1-mini
# TTS_MODEL=cartesia/sonic-3
# TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
# OPENAI_API_KEY=sk-...
# DEEPGRAM_API_KEY=...
# CARTESIA_API_KEY=...

# =============================================================================
# SIP — outbound calls from agent worker
# =============================================================================
SIP_TRUNK_ID=ST_...

# =============================================================================
# Admin web console (call-management-admin)
# =============================================================================
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-run

# WebAuthn passkeys — must match how users open the UI in the browser
# Local dev:
ADMIN_RP_ID=localhost
ADMIN_ORIGIN=http://localhost:8080
# Production subpath example (include /callmgmt in ORIGIN):
# ADMIN_RP_ID=paymercadogo.com
# ADMIN_ORIGIN=https://paymercadogo.com/callmgmt
# Production dedicated host:
# ADMIN_RP_ID=call.example.com
# ADMIN_ORIGIN=https://call.example.com

# ADMIN_AUTH_DISABLED=true
# ADMIN_SESSION_HOURS=168
# ADMIN_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# =============================================================================
# Application data
# =============================================================================
LOG_LEVEL=INFO
CRM_DB_PATH=./data/crm.db
ADMIN_AUTH_DB_PATH=./data/admin_auth.db
# Optional Postgres (stub — per-tenant SQLite used until asyncpg adapter)
# CRM_DATABASE_URL=postgresql://user:pass@localhost/callmgmt
# Max simultaneous calls per tenant (in-process queue; worker process)
MAX_CONCURRENT_CALLS_PER_TENANT=12
# Per-agent and per-DID caps: Admin → Mis agentes (optional, stricter than tenant cap)
DEFAULT_LOCALE=en
VIP_SKIP_RECEPTIONIST=true
ENABLE_POST_CALL_SUMMARY=true
SUMMARY_LLM_MODEL=grok-3-mini

# Local browser recordings (playground voice/chat upload)
# RECORDINGS_DIR=./data/recordings

# SIP/LiveKit phone recordings via LiveKit Egress (S3 or MinIO)
# RECORDINGS_S3_BUCKET=callmgmt-recordings
# RECORDINGS_S3_ACCESS_KEY=
# RECORDINGS_S3_SECRET=
# RECORDINGS_S3_REGION=us-east-1
# RECORDINGS_S3_ENDPOINT=https://paymercadogo.com
# Path-style bucket URL: https://paymercadogo.com/callmgmt-recordings/...
# Do NOT use https://domain/s3 if nginx strips the /s3/ prefix (SignatureDoesNotMatch).
# RECORDINGS_S3_FORCE_PATH_STYLE=true
# RECORDINGS_S3_PREFIX=callmanagement/recordings

# Escalation notifications
# ESCALATION_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Warm transfer tuning
WARM_TRANSFER_WAIT_SECONDS=8

# =============================================================================
# Admin UI build (production subpath — not read at runtime)
# Build with: cd admin-ui && VITE_BASE=/callmgmt/ npm run build
# See docs/DEPLOYMENT.md
# =============================================================================